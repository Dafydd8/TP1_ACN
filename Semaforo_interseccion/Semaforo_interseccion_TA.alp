			<InitialSetupCode><![CDATA[try {
    java.io.PrintWriter writer = new java.io.PrintWriter(
        new java.io.FileWriter("resultados_TA.csv", false)
    );

    writer.println("id,dpi,max_cola_norte,max_cola_sureste1,max_cola_sureste2,throughput,sin_camino,pvc");
    writer.close();

} catch (Exception e) {
