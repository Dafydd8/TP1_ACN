							<Value Class="CodeValue">
								<Code><![CDATA[car.waitTime = time() - car.enterTime;
statsEspera.add(car.waitTime);
throughput++;
if (statsEspera.count() > 10) {
    dataEspera.add(throughput, statsEspera.mean());
}
traceln("waitTime calculado: " + (time() - car.enterTime));]]></Code>
