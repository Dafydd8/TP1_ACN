							<Value Class="CodeValue">
								<Code><![CDATA[if(time() > 900){
	if (car.origen.equals("norte")) {
	    cola_norte++;
	    max_cola_norte = max(max_cola_norte, cola_norte);
	}
	if (car.origen.equals("sureste1")) {
	    cola_sureste1++;
	    max_cola_sureste1 = max(max_cola_sureste1, cola_sureste1);
	}
	if (car.origen.equals("sureste2")) {
	    cola_sureste2++;
	    max_cola_sureste2 = max(max_cola_sureste2, cola_sureste2);
	}
}]]></Code>
