		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1777514174268">
			<Id>1777519237377</Id>
			<Name><![CDATA[runs]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[try {
    java.io.PrintWriter writer = new java.io.PrintWriter(
        new java.io.FileWriter("resultados_TB.csv", false)
    );

    writer.println("id,dpi,max_cola_norte,max_cola_sureste1,max_cola_sureste2,throughput,pvc");
    writer.close();

} catch (Exception e) {
    traceln("Error: " + e);
}]]></InitialSetupCode>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>fixedSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<BeforeSimulationRunCode><![CDATA[root.getDefaultRandomGenerator().setSeed(1000 + getCurrentReplication());
traceln("seed"+ root.getDefaultRandomGenerator().toString());]]></BeforeSimulationRunCode>
			<AfterSimulationRunCode><![CDATA[double tiempoHoras = (time() - 900) / 3600.0;

double throughputHora = root.throughput / tiempoHoras;

double totalEntraron = root.cont_buses + root.cont_autos;

double PVC = totalEntraron > 0 ? (double) root.throughput / totalEntraron : 0;

double DPI = root.statsDPI.mean();

try {
    java.io.PrintWriter writer = new java.io.PrintWriter(
        new java.io.FileWriter("resultados_TB.csv", true)
    );

    writer.printf(
        java.util.Locale.US,
        "%d,%.6f,%.6f,%.6f,%.6f,%.6f,%.6f%n",
        runId,
        DPI,
        root.max_cola_norte,
        root.max_cola_sureste1,
        root.max_cola_sureste2,
        throughputHora,
        PVC
    );

    writer.close();

} catch (Exception e) {
    traceln("Error: " + e);
}
runId++;]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
